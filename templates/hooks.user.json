{
  "version": 1,
  "_comment": "God's Eye user-level hooks — merged by install.sh. Pause Touch 3 via touch3.disabled marker (session-stop.sh no-ops); keep stop hook. Paths relative to ~/.cursor/",
  "hooks": {
    "sessionStart": [
      {
        "command": "./hooks/gods-eye/session-start.sh",
        "timeout": 5
      }
    ],
    "stop": [
      {
        "command": "./hooks/gods-eye/session-stop.sh",
        "timeout": 5,
        "loop_limit": 1
      }
    ],
    "afterFileEdit": [
      {
        "command": "./hooks/gods-eye/after-file-edit.sh",
        "timeout": 5
      }
    ]
  }
}
