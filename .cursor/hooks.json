{
  "version": 1,
  "_comment": "God's Eye Phase 2 — optional soft hooks. Pause Touch 3 via .cursor/touch3.disabled marker (session-stop.sh no-ops); do not remove stop hook. See docs/HOOKS_SETUP.md.",
  "hooks": {
    "sessionStart": [
      {
        "command": ".cursor/hooks/session-start.sh",
        "timeout": 5
      }
    ],
    "stop": [
      {
        "command": ".cursor/hooks/session-stop.sh",
        "timeout": 5,
        "loop_limit": 1
      }
    ],
    "afterFileEdit": [
      {
        "command": ".cursor/hooks/after-file-edit.sh",
        "timeout": 5
      }
    ]
  }
}
